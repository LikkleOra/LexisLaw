# LexisLaw Platform Environment Variables
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
# CONVEX
# ═══════════════════════════════════════════════════════════════
# Get from Convex dashboard after running `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-name

# ═══════════════════════════════════════════════════════════════
# CLERK AUTHENTICATION
# ═══════════════════════════════════════════════════════════════
# Get from clerk.com dashboard
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# ═══════════════════════════════════════════════════════════════
# TWILIO (WhatsApp & SMS)
# ═══════════════════════════════════════════════════════════════
# Sign up at twilio.com
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238871  # Twilio sandbox number

# ═══════════════════════════════════════════════════════════════
# CLICKATELL (Alternative SMS)
# ═══════════════════════════════════════════════════════════════
# Sign up at clickatell.com
CLICKATELL_API_KEY=your_api_key

# ═══════════════════════════════════════════════════════════════
# ADMIN
# ═══════════════════════════════════════════════════════════════
ADMIN_PHONE=+2785962689
ADMIN_EMAIL=info@lexislaw.co.za
ADMIN_PASSWORD=lexislaw2026

# ═══════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=development
